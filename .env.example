# Token you get from @BotFather when creating your bot
BOT_TOKEN=123456789:AAabcDEFghiJKLmnoPQRstuVWXyz

# Port the server listens on (most hosts set this automatically)
PORT=3000

# The exact origin where your frontend (index.html) is hosted, e.g.:
# https://yourname.github.io
# Use * only for quick local testing.
FRONTEND_ORIGIN=*
